<p style="color: green"><%= notice %></p>
<h1>Articles</h1>

<div id="articles">
  <% @articles.each do |article| %>
    <%= render article %>
    <p>
      <%= link_to "Show this article", article %>
    </p>
  <% end %>
</div>

<%= cl_image_tag("rxcyh8zqlko6vad3g2uh",
      width: 150, height: 150, crop: :thumb, gravity: :face) %>
<%= link_to "New article", new_article_path %>
